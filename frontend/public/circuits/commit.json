{"noir_version":"1.0.0-beta.9+6abff2f16e1c1314ba30708d1cf032a536de3d19","hash":"5884536268902170616","abi":{"parameters":[{"name":"direction","type":{"kind":"field"},"visibility":"private"},{"name":"amount","type":{"kind":"field"},"visibility":"public"},{"name":"salt","type":{"kind":"field"},"visibility":"private"},{"name":"commitment","type":{"kind":"field"},"visibility":"public"},{"name":"min_amount","type":{"kind":"field"},"visibility":"public"},{"name":"max_amount","type":{"kind":"field"},"visibility":"public"}],"return_type":null,"error_types":{"4334300103244425590":{"error_kind":"string","string":"bet above maximum"},"5105182163440935742":{"error_kind":"string","string":"bet below minimum"},"10153942773597274279":{"error_kind":"string","string":"direction must be 0 or 1"},"16407765477254731130":{"error_kind":"string","string":"commitment mismatch"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"use dep::std::hash::poseidon2_permutation;\n\nfn main(\n    direction: Field,\n    amount: pub Field,\n    salt: Field,\n    commitment: pub Field,\n    min_amount: pub Field,\n    max_amount: pub Field,\n) {\n    let hash_state: [Field; 4] = poseidon2_permutation([direction, amount, salt, 0], 4);\n    let computed_commitment = hash_state[0];\n    assert(computed_commitment == commitment, \"commitment mismatch\");\n\n    assert(direction * (direction - 1) == 0, \"direction must be 0 or 1\");\n\n    assert(amount as u64 >= min_amount as u64, \"bet below minimum\");\n    assert(amount as u64 <= max_amount as u64, \"bet above maximum\");\n}\n","path":"/home/preyanshu/stellarhack/circuits/commit/src/main.nr"}},"names":["main"],"brillig_names":["directive_integer_quotient","directive_invert"]}