{"noir_version":"1.0.0-beta.9+6abff2f16e1c1314ba30708d1cf032a536de3d19","hash":"13525394678201031532","abi":{"parameters":[{"name":"claim_type","type":{"kind":"field"},"visibility":"public"},{"name":"category_code","type":{"kind":"field"},"visibility":"public"},{"name":"window_days","type":{"kind":"field"},"visibility":"public"},{"name":"threshold_or_band","type":{"kind":"field"},"visibility":"public"},{"name":"subject","type":{"kind":"field"},"visibility":"public"},{"name":"snapshot_commitment","type":{"kind":"field"},"visibility":"public"},{"name":"metric_value","type":{"kind":"field"},"visibility":"private"},{"name":"eligible_count","type":{"kind":"field"},"visibility":"private"},{"name":"witness_secret","type":{"kind":"field"},"visibility":"private"},{"name":"peer_scores","type":{"kind":"array","length":16,"type":{"kind":"field"}},"visibility":"private"},{"name":"peer_eligible","type":{"kind":"array","length":16,"type":{"kind":"field"}},"visibility":"private"}],"return_type":null,"error_types":{"5019202896831570965":{"error_kind":"string","string":"attempt to add with overflow"},"7233212735005103307":{"error_kind":"string","string":"attempt to multiply with overflow"},"9662417557529844592":{"error_kind":"string","string":"peer eligibility must be binary"},"10812171070531257542":{"error_kind":"string","string":"eligible set must be non-empty"},"16799344454331407715":{"error_kind":"string","string":"threshold failed"},"17285080625029639753":{"error_kind":"string","string":"snapshot mismatch"},"18361436867208434872":{"error_kind":"string","string":"percentile band failed"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"use dep::std::hash::poseidon2_permutation;\n\nfn main(\n    claim_type: pub Field,\n    category_code: pub Field,\n    window_days: pub Field,\n    threshold_or_band: pub Field,\n    subject: pub Field,\n    snapshot_commitment: pub Field,\n    metric_value: Field,\n    eligible_count: Field,\n    witness_secret: Field,\n    peer_scores: [Field; 16],\n    peer_eligible: [Field; 16],\n) {\n    let snapshot_hash: [Field; 4] = poseidon2_permutation(\n        [subject, category_code, window_days, witness_secret],\n        4,\n    );\n    assert(snapshot_hash[0] == snapshot_commitment, \"snapshot mismatch\");\n\n    if claim_type == 5 {\n        assert(eligible_count as u64 > 0, \"eligible set must be non-empty\");\n\n        let mut rank: u64 = 1;\n        for i in 0..16 {\n            assert(peer_eligible[i] * (peer_eligible[i] - 1) == 0, \"peer eligibility must be binary\");\n            if peer_eligible[i] == 1 {\n                if peer_scores[i] as u64 > metric_value as u64 {\n                    rank += 1;\n                }\n            }\n        }\n\n        assert(rank * 100 <= (eligible_count as u64) * (threshold_or_band as u64), \"percentile band failed\");\n    } else {\n        assert(metric_value as u64 >= threshold_or_band as u64, \"threshold failed\");\n    }\n}\n","path":"/home/preyanshu/stellarhack/circuits/reputation/src/main.nr"}},"names":["main"],"brillig_names":["directive_invert","directive_integer_quotient"]}