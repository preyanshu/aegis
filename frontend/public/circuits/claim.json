{"noir_version":"1.0.0-beta.9+6abff2f16e1c1314ba30708d1cf032a536de3d19","hash":"15959192580605926821","abi":{"parameters":[{"name":"direction","type":{"kind":"field"},"visibility":"private"},{"name":"amount","type":{"kind":"field"},"visibility":"public"},{"name":"salt","type":{"kind":"field"},"visibility":"private"},{"name":"commitment","type":{"kind":"field"},"visibility":"public"},{"name":"outcome","type":{"kind":"field"},"visibility":"public"},{"name":"nullifier","type":{"kind":"field"},"visibility":"public"}],"return_type":null,"error_types":{"7825517353209353775":{"error_kind":"string","string":"only winning bets can claim"},"10153942773597274279":{"error_kind":"string","string":"direction must be 0 or 1"},"13793952391589606628":{"error_kind":"string","string":"nullifier mismatch"},"16407765477254731130":{"error_kind":"string","string":"commitment mismatch"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"use dep::std::hash::poseidon2_permutation;\n\nfn main(\n    direction: Field,\n    amount: pub Field,\n    salt: Field,\n    commitment: pub Field,\n    outcome: pub Field,\n    nullifier: pub Field,\n) {\n    let hash_state: [Field; 4] = poseidon2_permutation([direction, amount, salt, 0], 4);\n    let computed_commitment = hash_state[0];\n    assert(computed_commitment == commitment, \"commitment mismatch\");\n\n    let nullifier_state: [Field; 4] = poseidon2_permutation([salt, 12345, 0, 0], 4);\n    let computed_nullifier = nullifier_state[0];\n    assert(computed_nullifier == nullifier, \"nullifier mismatch\");\n\n    assert(direction * (direction - 1) == 0, \"direction must be 0 or 1\");\n    assert(direction == outcome, \"only winning bets can claim\");\n}\n","path":"/home/preyanshu/stellarhack/circuits/claim/src/main.nr"}},"names":["main"],"brillig_names":[]}