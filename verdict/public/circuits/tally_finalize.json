{"noir_version":"1.0.0-beta.9+6abff2f16e1c1314ba30708d1cf032a536de3d19","hash":"12874203881424612512","abi":{"parameters":[{"name":"market_id","type":{"kind":"field"},"visibility":"public"},{"name":"final_tally_commitment","type":{"kind":"field"},"visibility":"public"},{"name":"outcome","type":{"kind":"field"},"visibility":"public"},{"name":"winning_side_total","type":{"kind":"field"},"visibility":"public"},{"name":"directions","type":{"kind":"array","length":16,"type":{"kind":"field"}},"visibility":"private"},{"name":"amounts","type":{"kind":"array","length":16,"type":{"kind":"field"}},"visibility":"private"},{"name":"salts","type":{"kind":"array","length":16,"type":{"kind":"field"}},"visibility":"private"},{"name":"included","type":{"kind":"array","length":16,"type":{"kind":"field"}},"visibility":"private"}],"return_type":null,"error_types":{"1032346429852287636":{"error_kind":"string","string":"winning total mismatch"},"3928246044679478675":{"error_kind":"string","string":"winning total must be positive"},"6759725529159728696":{"error_kind":"string","string":"final tally commitment mismatch"},"6926192466887757770":{"error_kind":"string","string":"outcome must be binary"},"8339744684388391893":{"error_kind":"string","string":"included must be binary"},"9989336672818484819":{"error_kind":"string","string":"direction must be binary"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"use dep::std::hash::poseidon2_permutation;\n\nfn main(\n    market_id: pub Field,\n    final_tally_commitment: pub Field,\n    outcome: pub Field,\n    winning_side_total: pub Field,\n    directions: [Field; 16],\n    amounts: [Field; 16],\n    salts: [Field; 16],\n    included: [Field; 16],\n) {\n    assert(outcome * (outcome - 1) == 0, \"outcome must be binary\");\n\n    let mut tally_commitment = 0;\n    let mut yes_total = 0;\n    let mut no_total = 0;\n\n    for i in 0..16 {\n        assert(included[i] * (included[i] - 1) == 0, \"included must be binary\");\n\n        if included[i] == 1 {\n            let side = directions[i];\n            let amount = amounts[i];\n            let salt = salts[i];\n\n            assert(side * (side - 1) == 0, \"direction must be binary\");\n\n            let commitment_state: [Field; 4] = poseidon2_permutation([market_id, side, amount, salt], 4);\n            let commitment = commitment_state[0];\n\n            let tally_state: [Field; 4] = poseidon2_permutation([tally_commitment, commitment, amount, side], 4);\n            tally_commitment = tally_state[0];\n\n            if side == 1 {\n                yes_total += amount;\n            } else {\n                no_total += amount;\n            }\n        }\n    }\n\n    assert(tally_commitment == final_tally_commitment, \"final tally commitment mismatch\");\n\n    let computed_winning_total = if outcome == 1 { yes_total } else { no_total };\n    assert(computed_winning_total == winning_side_total, \"winning total mismatch\");\n    assert(winning_side_total as u64 > 0, \"winning total must be positive\");\n}\n","path":"/home/preyanshu/stellarhack/circuits/tally_finalize/src/main.nr"}},"names":["main"],"brillig_names":["directive_invert","directive_integer_quotient"]}