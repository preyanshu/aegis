{"noir_version":"1.0.0-beta.9+6abff2f16e1c1314ba30708d1cf032a536de3d19","hash":"3006933052091330138","abi":{"parameters":[{"name":"direction","type":{"kind":"field"},"visibility":"private"},{"name":"amount","type":{"kind":"field"},"visibility":"private"},{"name":"salt","type":{"kind":"field"},"visibility":"private"},{"name":"commitment","type":{"kind":"field"},"visibility":"public"},{"name":"market_id","type":{"kind":"field"},"visibility":"public"},{"name":"outcome","type":{"kind":"field"},"visibility":"public"},{"name":"nullifier","type":{"kind":"field"},"visibility":"public"},{"name":"distributable_pot","type":{"kind":"field"},"visibility":"public"},{"name":"winning_side_total","type":{"kind":"field"},"visibility":"public"},{"name":"payout","type":{"kind":"field"},"visibility":"public"}],"return_type":null,"error_types":{"7452001079866647768":{"error_kind":"string","string":"payout mismatch"},"7825517353209353775":{"error_kind":"string","string":"only winning bets can claim"},"10153942773597274279":{"error_kind":"string","string":"direction must be 0 or 1"},"13723972734715787563":{"error_kind":"string","string":"winning side total must be positive"},"13793952391589606628":{"error_kind":"string","string":"nullifier mismatch"},"16407765477254731130":{"error_kind":"string","string":"commitment mismatch"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"use dep::std::hash::poseidon2_permutation;\n\nfn main(\n    direction: Field,\n    amount: Field,\n    salt: Field,\n    commitment: pub Field,\n    market_id: pub Field,\n    outcome: pub Field,\n    nullifier: pub Field,\n    distributable_pot: pub Field,\n    winning_side_total: pub Field,\n    payout: pub Field,\n) {\n    let hash_state: [Field; 4] = poseidon2_permutation([market_id, direction, amount, salt], 4);\n    let computed_commitment = hash_state[0];\n    assert(computed_commitment == commitment, \"commitment mismatch\");\n\n    let nullifier_state: [Field; 4] = poseidon2_permutation([market_id, salt, 12345, 0], 4);\n    let computed_nullifier = nullifier_state[0];\n    assert(computed_nullifier == nullifier, \"nullifier mismatch\");\n\n    assert(direction * (direction - 1) == 0, \"direction must be 0 or 1\");\n    assert(direction == outcome, \"only winning bets can claim\");\n    assert(winning_side_total as u64 > 0, \"winning side total must be positive\");\n    assert((amount * distributable_pot) / winning_side_total == payout, \"payout mismatch\");\n}\n","path":"/home/preyanshu/stellarhack/circuits/claim/src/main.nr"}},"names":["main"],"brillig_names":["directive_integer_quotient","directive_invert"]}